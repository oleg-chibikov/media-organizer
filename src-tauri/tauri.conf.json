{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Media Organizer",
  "version": "0.1.0",
  "identifier": "com.mediaorganizer.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Media Organizer",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [],
    "externalBin": ["binaries/exiftool"]
  }
}
